# Copiez ce fichier en ".env" et adaptez les valeurs si besoin
PORT=4100
JWT_SECRET=changez-moi-en-production-secret-tres-long
CLIENT_ORIGIN=http://localhost:5173

# Compte propriétaire (super-admin) CACHÉ — facultatif.
# S'il est défini, un compte admin invisible est créé/mis à jour au démarrage :
# absent de la liste des utilisateurs, non supprimable, actions non journalisées.
# À configurer côté hébergeur (Railway → Variables), pas dans le dépôt.
# SUPERADMIN_USER=votre-identifiant-secret
# SUPERADMIN_PASS=un-mot-de-passe-long-et-unique
